generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())

  fullName          String
  email             String   @unique
  password          String

  refreshToken      String?

  resetToken        String?
  resetTokenExpiry  DateTime?

  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}